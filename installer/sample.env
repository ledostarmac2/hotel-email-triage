# ReplyRight sample deployment configuration
#
# Copy this file next to ReplyRight.exe as ".env" only for owner/dev-managed
# installs. End users should never be asked to paste API keys into ReplyRight.
# Official owner-built installers can receive these values from GitHub Actions
# release secrets or another deployment-time provisioning process.
#
# SECURITY
# - Never share your .env file.
# - Never commit service-role keys or provider API keys.
# - SUPABASE_SERVICE_ROLE_KEY is privileged and should be provisioned only by
#   the owner/IT administrator.

# Supabase (required for shared users, feedback sync, and training review)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Seeded admin account for owner-built releases
REPLYRIGHT_ADMIN_EMAIL=
REPLYRIGHT_ADMIN_PASSWORD=

# AI providers (optional; local deterministic triage still works without them)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-3-flash-preview
# Claude is for explicit single-email Analyze/AI Suggestion only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# SMTP for invite/reset emails. If blank, admins can copy manual invite links.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Application
APP_HOST=127.0.0.1
APP_PORT=8000

# Outlook source
OUTLOOK_EXPORT_MAILBOX=NYCWA_Reservations
OUTLOOK_EXPORT_FOLDER=Inbox

# Database (leave blank to use default location)
# Default packaged path: %LOCALAPPDATA%\Programs\ReplyRight\data\hotel_email_triage.sqlite3
SQLITE_DB_PATH=
