generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PriorityLevel {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum BusinessCategory {
  ARRIVAL_TODAY
  VIP_OWNER_CELEBRITY
  FHR_CENTURION
  HILTON_FOR_LUXURY_IMPRESARIO
  VIRTUOSO
  PAYMENT_NEEDED_CCA_SERTIFI
  AGENT_QUOTE_REQUEST
  RATE_MATCH
  WAITLIST
  GUEST_COMPLAINT
  FOLIO_REQUEST
  CANCELLATION_MODIFICATION
  INTERNAL_FYI
  DUPLICATE_FOLLOW_UP
  LOW_PRIORITY
}

enum ProcessingStatus {
  FETCHED
  CLASSIFIED
  APPLIED
  OVERRIDDEN
  FAILED
}

model Mailbox {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailAddress String @unique
  displayName  String?
  provider     String @default("microsoft")
  isEnabled    Boolean @default(true)

  emails EmailMessage[]
  categoryMappings CategoryMapping[]
}

model EmailMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailboxId String
  mailbox   Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  graphMessageId     String
  internetMessageId  String?
  conversationId     String?
  subject            String
  senderEmail        String
  senderName         String?
  toRecipients       Json
  ccRecipients       Json
  receivedDateTime   DateTime
  bodyPreview        String?
  sanitizedBody      String?
  hasAttachments     Boolean @default(false)
  attachments        Json
  outlookCategories  String[]
  isRead             Boolean @default(false)
  isFlagged          Boolean @default(false)
  status             ProcessingStatus @default(FETCHED)

  classifications Classification[]
  actionLogs      ActionLog[]
  overrides       ManualOverride[]

  @@unique([mailboxId, graphMessageId])
  @@index([mailboxId, receivedDateTime])
  @@index([status])
  @@index([senderEmail])
}

model Classification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  priority               PriorityLevel
  category               BusinessCategory
  reason                 String
  requiredAction         String?
  recommendedDeadline    String
  suggestedCategoryColor String
  outlookCategories      String[]
  triggerEvidence        Json
  redactionSummary       Json
  model                  String
  promptVersion          String
  rawModelOutput         Json
  confidence             Float?

  @@index([priority])
  @@index([category])
  @@index([createdAt])
}

model CategoryMapping {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mailboxId String
  mailbox   Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  key             String
  outlookCategory String
  outlookColor    String
  isEnabled       Boolean @default(true)

  @@unique([mailboxId, key])
}

model ManualOverride {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  previousPriority PriorityLevel?
  previousCategory BusinessCategory?
  newPriority      PriorityLevel
  newCategory      BusinessCategory
  reason           String?
  actorEmail       String
}

model ClassificationFeedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  classificationId String
  decisionType     String
  feedback         String
  correctValue     String?
  actorEmail       String
}

model ActionLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  emailMessageId String?
  emailMessage   EmailMessage? @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)

  action     String
  status     String
  details    Json
  error      String?
  dryRun     Boolean @default(true)
}
