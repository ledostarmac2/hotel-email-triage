MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback
SHARED_MAILBOX_EMAIL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Optional Google AI Studio / Gemini fallback for refresh classification.
# Store your own rotated key locally; do not paste shared/leaked keys.
# You can run .\scripts\configure_google_ai_studio.ps1 to update ignored .env safely.
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-3-flash-preview

# Anthropic / Claude (preferred — used first when set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Optional — Semantic Kernel orchestration layer log level (DEBUG/INFO/WARNING)
KERNEL_LOG_LEVEL=INFO
# Supabase — shared learning / feedback upload (optional; leave blank to disable)
SUPABASE_URL=https://dxalumiijcfmwzmosijf.supabase.co
SUPABASE_KEY=

SQLITE_DB_PATH=data/hotel_email_triage.sqlite3
OUTLOOK_EXPORT_MAILBOX=NYCWA_Reservations
OUTLOOK_EXPORT_FOLDER=Inbox
OUTLOOK_EXPORT_DIR=data/outlook_exports
OUTLOOK_EXPORT_MACRO=ExportNYCWAReservationsInboxOnly
APP_HOST=127.0.0.1
APP_PORT=8000
REPLYRIGHT_ADMIN_EMAIL=
REPLYRIGHT_ADMIN_PASSWORD=

# SMTP — used for password recovery emails
# Office 365: smtp.office365.com:587   Gmail: smtp.gmail.com:587
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
