MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback
SHARED_MAILBOX_EMAIL=
OPENAI_API_KEY=

# Optional — dashboard default is gpt-4.1-mini; kernel layer default is gpt-5.5
OPENAI_MODEL=gpt-4.1-mini

# Optional — Semantic Kernel orchestration layer log level (DEBUG/INFO/WARNING)
KERNEL_LOG_LEVEL=INFO
SQLITE_DB_PATH=data/hotel_email_triage.sqlite3
OUTLOOK_EXPORT_MAILBOX=NYCWA_Reservations
OUTLOOK_EXPORT_FOLDER=Inbox
OUTLOOK_EXPORT_DIR=data/outlook_exports
OUTLOOK_EXPORT_MACRO=ExportNYCWAReservationsInboxOnly
APP_HOST=127.0.0.1
APP_PORT=8000
