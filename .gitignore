labeling/Claude/*.json
labeling/ChatGPT/*.json
labeling/agent_batches/*.json
labeling/runs/*.json
# Export files (Markdown labeling batches) may contain redacted guest/staff context
labeling/exports/*.md
labeling/exports/*.json
labeling/exports/*.txt
# Any future labeling batch format
labeling/agent_batches/*.md

